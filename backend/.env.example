# Backend environment template
# For Render + Neon production, set DATABASE_URL and leave DB_* empty.

# Environment
ENVIRONMENT=production
PORT=8000

# Database (preferred for Render/Neon)
# Example: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Legacy local MySQL fallback (optional)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=stylarkx_db

# Email (Gmail SMTP)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=StylarkX
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
USE_CREDENTIALS=True
VALIDATE_CERTS=True

# Business email that receives inquiry notifications
COMPANY_EMAIL=hello@stylarkx.com

# Frontend URL and CORS
FRONTEND_URL=http://localhost:5173
# Comma-separated exact origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional regex for preview domains (e.g. Vercel previews)
CORS_ALLOW_ORIGIN_REGEX=^https://.*\.vercel\.app$
